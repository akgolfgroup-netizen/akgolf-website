# ============================================================
# AK Golf Website + Portal — Environment Variables
# ============================================================

# --- Supabase (Auth + Website DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal Database (Prisma) ---
DATABASE_URL=postgresql://user:password@host:5432/akgolf_booking

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_BASIS=price_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# --- Vipps (Norwegian payments, portal) ---
VIPPS_CLIENT_ID=your_client_id
VIPPS_CLIENT_SECRET=your_client_secret
VIPPS_SUBSCRIPTION_KEY=your_subscription_key
VIPPS_MERCHANT_SERIAL_NUMBER=your_msn
VIPPS_IS_TEST=true

# --- Anthropic Claude (AI) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Resend (Email) ---
RESEND_API_KEY=re_PLACEHOLDER
CONTACT_EMAIL=post@akgolf.no

# --- Twilio (SMS, portal) ---
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+47xxxxxxxx

# --- Google OAuth (via Supabase Auth provider) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- DataGolf API (portal) ---
DATAGOLF_API_KEY=your_api_key

# --- Notion ---
NOTION_API_KEY=ntn_your_api_key_here
NOTION_BRAND_GUIDE_DB_ID=caa4fdd02e2f4865aaeef4ad923be925

# --- Formspree ---
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here
